# Variables para docker compose. Copia a  .env.docker  y ajusta.
# (.env.docker está en .gitignore; NO lo subas.)

# --- Django (lee core/conf.py) ---
# Genera una clave: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False
# Incluye el nombre del servicio 'api' para el healthcheck interno y localhost para el host.
ALLOWED_HOSTS=localhost,127.0.0.1,api
# Si sirves el admin tras https/proxy, añade el origen (con esquema):
CSRF_TRUSTED_ORIGINS=
# Detrás de TLS real (proxy/Ingress con certificado) activa el bloque HTTPS completo
# (SSL redirect + HSTS + cookies secure). En Compose local déjalo apagado (HTTP plano).
# SECURE_HTTPS=True

# Rate limiting de la API (opcional; defaults: 60/min anon, 300/min user, 10/min token).
# THROTTLE_ANON=60/min
# THROTTLE_USER=300/min
# THROTTLE_TOKEN=10/min

# --- PostgreSQL (servicio 'db') ---
# docker-compose.yml arma DATABASE_URL a partir de estas variables.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=all_in_django

# --- Token de la API para la UI (la API exige autenticación) ---
# Tras el primer 'up': crea usuario y token dentro del contenedor api y pégalo aquí.
#   docker compose --env-file .env.docker exec api python manage.py createsuperuser
#   docker compose --env-file .env.docker exec api python manage.py drf_create_token <usuario>
API_TOKEN=

# Nota: DATABASE_URL NO se define aquí; el compose la construye apuntando a 'db:5432'.
