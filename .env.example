# Configuración de All in Django — leída por pydantic-settings (core/conf.py).
# Copia este archivo a   .env   y completa los valores. NO subas .env al repositorio.

# Seguridad (obligatorio para producción: define SECRET_KEY si DEBUG=False)
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Endurecimiento HTTPS (SSL redirect + HSTS + cookies secure). Actívalo SOLO cuando
# la app esté detrás de TLS real (proxy/Ingress con certificado); en local/Compose
# se sirve HTTP plano y forzarlo rompería el healthcheck.
# SECURE_HTTPS=True

# Rate limiting de la API (formato "<n>/<periodo>": second, minute, hour, day).
# THROTTLE_ANON=60/min
# THROTTLE_USER=300/min
# THROTTLE_TOKEN=10/min

# Base de datos. Sin DATABASE_URL se usa SQLite local (db.sqlite3).
# Para PostgreSQL, descomenta y ajusta usuario/clave/host/puerto/base:
# DATABASE_URL=postgres://all_in_django:changeme@localhost:5432/all_in_django

# Credenciales de los logins automáticos (management command: login_menu)
CISCO_USER=
CISCO_PASS=
SENCE_RUT=
CLAVE_UNICA=

# Carpeta data/ de all_in_one (para el comando importar_all_in_one).
# Por defecto: ../all_in_one/data
# ALL_IN_ONE_DATA=C:\dev\projects\all_in_one\data
